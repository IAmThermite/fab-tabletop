<.error_shell status={404} title="Page Not Found" page_title="404 — Page Not Found">
  <:flavor>
    This page isn't even in your banished zone...
  </:flavor>
  <:actions>
    <.link href={~p"/"} class="btn btn-primary">Return to the lobby</.link>
    <.link href={~p"/about"} class="btn btn-ghost">How it works</.link>
  </:actions>
</.error_shell>
