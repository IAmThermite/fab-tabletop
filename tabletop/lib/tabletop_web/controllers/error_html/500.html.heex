<.error_shell status={500} title="Failed to resolve" page_title="500 — Something Went Wrong">
  <:flavor>
    Your hero has fallen. The combat chain broke before this page could resolve.
  </:flavor>
  <:actions>
    <.link href={~p"/"} class="btn btn-primary">Return to the lobby</.link>
    <a
      href="https://discord.gg/25QAegj6gJ"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-ghost"
    >
      Report on Discord
    </a>
  </:actions>
</.error_shell>
